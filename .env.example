PRIMARY_TRANSCRIPTION_SERVICE=local  # or api
SOUND_NOTIFICATION_ON_COMPLETION=true # or false. Its useful if you are using local models and take sometime to transcribe
MOUSE_HOTKEY=xbutton1                  # xbutton1, xbutton2, middle, or disabled
CONSUME_MOUSE_HOTKEY=true              # prevents xbutton back/forward or middle-click behavior when used as the hotkey
AUTO_PASTE_AFTER_TRANSCRIBE=true       # Windows: copy to clipboard, restore original app focus, then send Ctrl+V
WHISPER_LANGUAGE=ru                    # ru, en, kk, or auto
# API backend (any OpenAI-compatible /v1/audio/transcriptions endpoint)
# API_BASE_URL=https://api.groq.com/openai/v1  # default (Groq)
# API_KEY=your_key_here
# API_MODEL=whisper-large-v3-turbo

# Transcript post-processing is toggled in-app (right-click menu -> "Обработка текста").
# Advanced optional overrides for the cleanup model:
# POST_PROCESSING_MODEL=llama-3.3-70b-versatile
# POST_PROCESSING_STYLE=structured

# Optional: local whisper model name for helper scripts (default local preset: ggml-tiny.bin)
# WHISPER_MODEL=ggml-tiny.bin
